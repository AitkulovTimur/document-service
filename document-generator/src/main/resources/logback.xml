<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight([%thread]) %highlight(%-5level) %magenta(%logger{36}) %white(-) %yellow(%msg%n)</pattern>
        </encoder>
    </appender>

    <logger name="org.apache.hc" level="INFO" />
    <logger name="org.apache.http" level="INFO" />

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>